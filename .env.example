# Runtime
LEAD_APP_NAME=lead-qualification-agent
LEAD_ENVIRONMENT=development
LEAD_LOG_LEVEL=INFO
LEAD_LOG_FORMAT=json

# Server
LEAD_HOST=0.0.0.0
LEAD_PORT=8000

# LLM provider (required only for POST /api/v1/lead/qualify)
LEAD_LLM_PROVIDER=openai
OPENAI_API_KEY=
LEAD_OPENAI_MODEL=gpt-4o-mini
LEAD_LLM_TIMEOUT_SECONDS=20
LEAD_LLM_MAX_RETRIES=2
LEAD_LLM_RETRY_BASE_DELAY_SECONDS=0.25
